{
  "name": "sua-ui-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Scalable SaaS platform for selling access to a multi-framework UI component library.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm dev:unified",
    "build": "pnpm -r --if-present run build",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm build && pnpm -r --if-present run test",
    "typecheck": "pnpm build && pnpm -r --if-present run typecheck",
    "clean": "pnpm -r --if-present run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,yml,yaml}\"",
    "db:generate": "pnpm --filter @sua-marca-ui/database db:generate",
    "db:migrate": "pnpm --filter @sua-marca-ui/database db:migrate",
    "db:push": "pnpm --filter @sua-marca-ui/database db:push",
    "db:seed": "pnpm --filter @sua-marca-ui/database db:seed",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "publish:public": "pnpm build && changeset publish",
    "publish:private": "pnpm build && pnpm --filter \"@sua-marca-ui-pro/*\" publish --no-git-checks",
    "storybook": "pnpm --filter storybook dev",
    "test:e2e": "pnpm -r --if-present run test:e2e",
    "services:doctor": "node tooling/scripts/services-doctor.mjs",
    "setup:env": "node tooling/scripts/setup-env.mjs",
    "services:up": "node tooling/scripts/services-up.mjs",
    "check:boundaries": "tsx tooling/scripts/check-package-boundaries.ts",
    "check:private-publish": "tsx tooling/scripts/check-private-publish-config.ts",
    "check:secrets": "tsx tooling/scripts/check-secrets.ts",
    "check:bundle-budget": "tsx tooling/scripts/check-bundle-budget.ts",
    "test:phase6": "pnpm --filter @sua-marca-ui/core test && pnpm --filter @sua-marca-ui/react test && pnpm --filter @sua-marca-ui/react build",
    "ci:quality": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:phase6 && pnpm check:bundle-budget && pnpm check:boundaries && pnpm check:private-publish && pnpm check:secrets",
    "dev:unified": "pnpm --parallel --filter @sua-marca-ui/marketing --filter @sua-marca-ui/docs --filter @sua-marca-ui/dashboard run dev",
    "dev:full": "pnpm -r --parallel --if-present run dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2"
  }
}
