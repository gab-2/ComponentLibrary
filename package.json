{
  "name": "sua-ui-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Scalable SaaS platform for selling access to a multi-framework UI component library.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss,yml,yaml}\"",
    "db:generate": "pnpm --filter @sua-marca/database db:generate",
    "db:migrate": "pnpm --filter @sua-marca/database db:migrate",
    "db:push": "pnpm --filter @sua-marca/database db:push",
    "db:seed": "pnpm --filter @sua-marca/database db:seed",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "publish:public": "pnpm build && changeset publish",
    "publish:private": "pnpm build && pnpm --filter \"@sua-marca-pro/*\" publish --no-git-checks",
    "storybook": "pnpm --filter storybook dev",
    "test:e2e": "turbo test:e2e",
    "services:doctor": "node tooling/scripts/services-doctor.mjs",
    "setup:env": "node tooling/scripts/setup-env.mjs",
    "services:up": "node tooling/scripts/services-up.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.11",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}