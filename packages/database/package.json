{
  "name": "@sua-marca/database",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc -v",
    "lint": "prettier --check package.json",
    "test": "pnpm db:generate && tsx --test tests/*.test.ts",
    "typecheck": "tsc -v",
    "db:generate": "prisma generate",
    "db:migrate": "node ../../tooling/scripts/run-with-db-url.mjs prisma migrate dev --name init",
    "db:push": "node ../../tooling/scripts/run-with-db-url.mjs prisma db push",
    "db:seed": "node ../../tooling/scripts/run-with-db-url.mjs tsx prisma/seed.ts",
    "db:studio": "node ../../tooling/scripts/run-with-db-url.mjs prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0"
  },
  "devDependencies": {
    "prisma": "^6.7.0",
    "tsx": "^4.20.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
