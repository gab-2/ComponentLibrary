{
  "theme": {
    "light": {
      "bg": {
        "canvas": "#f8fafc",
        "surface": "#ffffff",
        "elevated": "#ffffff",
        "primary": "#2563eb"
      },
      "text": {
        "primary": "#0f172a",
        "secondary": "#334155",
        "muted": "#64748b",
        "inverse": "#ffffff"
      },
      "border": {
        "default": "#cbd5e1",
        "focus": "#2563eb",
        "danger": "#dc2626"
      }
    },
    "dark": {
      "bg": {
        "canvas": "#020617",
        "surface": "#0f172a",
        "elevated": "#1e293b",
        "primary": "#3b82f6"
      },
      "text": {
        "primary": "#f8fafc",
        "secondary": "#e2e8f0",
        "muted": "#94a3b8",
        "inverse": "#0f172a"
      },
      "border": {
        "default": "#334155",
        "focus": "#60a5fa",
        "danger": "#f87171"
      }
    }
  },
  "spacing": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem"
  },
  "radius": { "sm": "6px", "md": "10px", "lg": "14px", "pill": "999px" },
  "motion": {
    "fast": "120ms",
    "base": "180ms",
    "slow": "260ms",
    "easing": "cubic-bezier(0.2, 0, 0, 1)"
  },
  "zIndex": { "base": 1, "overlay": 1000, "modal": 1100, "toast": 1200 },
  "components": {
    "input": {
      "light": {
        "bg": "#ffffff",
        "text": "#0f172a",
        "placeholder": "#64748b",
        "border": "#cbd5e1",
        "borderFocus": "#2563eb",
        "borderInvalid": "#dc2626",
        "ringFocusPointer": "color-mix(in srgb, #2563eb 18%, transparent)",
        "ringFocusKeyboard": "color-mix(in srgb, #2563eb 28%, transparent)",
        "ringInvalidPointer": "color-mix(in srgb, #dc2626 18%, transparent)",
        "ringInvalidKeyboard": "color-mix(in srgb, #dc2626 28%, transparent)",
        "caret": "#111827",
        "selectionBg": "#e5e7eb",
        "selectionText": "#111827",
        "shadow": "0 6px 18px rgba(15, 23, 42, 0.07)"
      },
      "dark": {
        "bg": "#190f1f",
        "text": "#e5e7eb",
        "placeholder": "#6b7280",
        "border": "color-mix(in srgb, #657ed4 20%, transparent)",
        "borderFocus": "color-mix(in srgb, #657ed4 50%, transparent)",
        "borderInvalid": "#ef4444",
        "ringFocusPointer": "color-mix(in srgb, #657ed4 20%, transparent)",
        "ringFocusKeyboard": "color-mix(in srgb, #657ed4 50%, transparent)",
        "ringInvalidPointer": "color-mix(in srgb, #ef4444 25%, transparent)",
        "ringInvalidKeyboard": "color-mix(in srgb, #ef4444 40%, transparent)",
        "caret": "#ffffff",
        "selectionBg": "#1f2937",
        "selectionText": "#ffffff",
        "shadow": "0 8px 24px rgba(0, 0, 0, 0.28)"
      }
    },
    "card": {
      "light": {
        "bg": "#ffffff",
        "text": "#0f172a",
        "border": "#cbd5e1",
        "borderHover": "#3b82f6",
        "shadow": "0 6px 18px rgba(15, 23, 42, 0.07)",
        "shadowHover": "0 12px 26px color-mix(in srgb, #3b82f6 10%, transparent)"
      },
      "dark": {
        "bg": "#190f1f",
        "text": "#e5e7eb",
        "border": "color-mix(in srgb, #657ed4 20%, transparent)",
        "borderHover": "color-mix(in srgb, #657ed4 50%, transparent)",
        "shadow": "0 8px 24px rgba(0, 0, 0, 0.28)",
        "shadowHover": "0 14px 28px color-mix(in srgb, #657ed4 10%, transparent)"
      }
    }
  }
}
